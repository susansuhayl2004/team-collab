# Environment Variables for TeamCollab
# ==============================================
# DO NOT put real keys here — this file is public on GitHub!
# Set real values in: Google Cloud Run → Edit & Deploy New Revision → Variables
# ==============================================

# Server Configuration
PORT=8080
NODE_ENV=production

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# CORS - your deployed Cloud Run URL
ALLOWED_ORIGINS=https://your-cloud-run-url.run.app