# Environment Variables for TeamCollab
# These are set in Google Cloud Run → Edit & Deploy New Revision → Variables

# Server Configuration
PORT=8080
NODE_ENV=production

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
# Must start with "AIza..."
GEMINI_API_KEY=your_gemini_api_key_here

# CORS - your Cloud Run service URL
ALLOWED_ORIGINS=https://team-collab-663758715.me-central1.run.app